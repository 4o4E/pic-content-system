# 后端进程读取：本地直接运行后端或容器内后端都会使用。
DATABASE_URL="postgresql://pic:pic_content_password@db:5432/pic_content_system?schema=public"
PORT=3000
FILES_DIR="./data/files"
ACCESS_TOKEN="123456"
BACKUP_DIR="/data/backups"
BACKUP_CRON="0 3 * * *"

# Docker Compose 读取：控制镜像、端口、迁移和宿主机目录挂载。
APP_PORT=3000
APP_IMAGE=pic-content-system:local
RUN_MIGRATIONS=true
HOST_BACKUP_DIR="F:/data/pic-content-system/backups"
