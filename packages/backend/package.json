{
  "name": "@pic/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:watch",
    "dev:watch": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "import:old-pic": "tsx scripts/import-old-pic.ts",
    "import:napcat-export": "tsx scripts/import-napcat-export.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@pic/shared": "workspace:*",
    "@prisma/client": "^6.8.0",
    "archiver": "^7.0.1",
    "fastify": "^5.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.8.0",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
